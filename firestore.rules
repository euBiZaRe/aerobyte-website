rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles
    match /users/{userId} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
      
      // Admin bypass: Owners can manage ANY user document (Read and Write)
      allow read, write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan == 'Owner';
    }
    
    // License Keys
    match /licenses/{licenseId} {
      allow read: if true;
      allow create: if request.auth != null;

      // Admin bypass: Owners can manage ANY license document (Update and Delete)
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan == 'Owner';
    }
    
    // Giveaway / Promo Codes
    match /promo_codes/{codeId} {
      allow read, update, delete: if request.auth != null;
      
      allow create: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan == 'Owner';
    }

    // System Status (Manages Active/Down state, Versioning, and Links)
    match /system_status/{productId} {
      allow read: if true; 
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan == 'Owner';
    }

    // Banned HWIDs
    match /banned_hwids/{hwid} {
      allow read: if true; 
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan == 'Owner';
    }

    // Global Configuration (Kill Switch)
    match /config/{configId} {
      allow read: if true; 
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan == 'Owner';
    }
  }
}
