rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles
    match /users/{userId} {
      // FORCE ACCESS: Allow all authenticated users to READ for now (to fix admin visibility)
      allow read: if request.auth != null;
      
      // Admin bypass for write
      allow write: if request.auth != null && 
        (request.auth.token.email == 'aerobytebot@gmail.com' || 
         request.auth.token.email == 'adamfrawi@gmail.com' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan == 'Owner');
    }
    
    // License Keys
    match /licenses/{licenseId} {
      allow read: if true;
      allow create: if request.auth != null;

      allow write: if request.auth != null && 
        (request.auth.token.email == 'aerobytebot@gmail.com' || 
         request.auth.token.email == 'adamfrawi@gmail.com' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan == 'Owner');
    }
    
    // Giveaway / Promo Codes
    match /promo_codes/{codeId} {
      // Users can check, update (mark used), and delete a code when they use it
      allow read, update, delete: if request.auth != null;
      
      allow create: if request.auth != null && 
        (request.auth.token.email == 'aerobytebot@gmail.com' || 
         request.auth.token.email == 'adamfrawi@gmail.com' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan == 'Owner');
    }
  }
}
